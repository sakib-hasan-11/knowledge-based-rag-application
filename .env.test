# ============================================================================
# .env.test - Test Environment Configuration for CI/CD Pipeline
# ============================================================================
# This file contains test environment variables for running the complete
# test suite in GitHub Actions CI/CD pipeline.
#
# WARNING: These are test/demo credentials and should NOT be used in production.
# For production, use GitHub Secrets to inject real credentials.
# ============================================================================

# ============================================================================
# AWS Configuration - Test Environment
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}

# ============================================================================
# S3 Configuration - Test Bucket for Document Storage
# ============================================================================
S3_BUCKET_NAME=${S3_TEST_BUCKET_NAME}
S3_DOCUMENT_PREFIX=raw_data/aapl-20250927.html

# ============================================================================
# OpenAI Configuration - API Keys and Models
# ============================================================================
OPENAI_API_KEY=${OPENAI_API_KEY}
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
GPT_MODEL_NAME=gpt-4-turbo
GPT_MODEL_TEMPERATURE=0.3

# ============================================================================
# Pinecone Configuration - Demo Index for Testing
# ============================================================================
PINECONE_API_KEY=${PINECONE_API_KEY}
PINECONE_INDEX_NAME=rag-ci-test
PINECONE_HOST=${PINECONE_HOST}
PINECONE_ENVIRONMENT=us-east-1
PINECONE_METRIC=cosine

# ============================================================================
# Data Ingestion Pipeline Configuration
# ============================================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=100
SIMILARITY_THRESHOLD=0.85
BATCH_SIZE=32
UPSERT_BATCH_SIZE=100

# ============================================================================
# Retrieval Pipeline Configuration
# ============================================================================
RETRIEVAL_TOP_K=10
HYBRID_ALPHA=0.5
MMR_DIVERSITY_FACTOR=0.5
TOKEN_LIMIT=4000
MAX_CONTEXT_LENGTH=2000

# ============================================================================
# Generation Pipeline Configuration
# ============================================================================
MAX_GENERATION_TOKENS=500
GENERATION_TEMPERATURE=0.3
ENABLE_CHAIN_OF_THOUGHT=true
ENABLE_HALLUCINATION_CHECK=true

# ============================================================================
# LangSmith Configuration - Tracing and Monitoring
# ============================================================================
LANGSMITH_API_KEY=${LANGSMITH_API_KEY}
LANGSMITH_PROJECT_NAME=rag-ci-test
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
ENABLE_LANGSMITH_TRACING=true

# ============================================================================
# RAGAS Metrics Configuration - Evaluation
# ============================================================================
RAGAS_BATCH_SIZE=10
RAGAS_TIMEOUT=30

# ============================================================================
# Evaluation Pipeline Configuration
# ============================================================================
ENABLE_REGRESSION_CHECK=true
REGRESSION_THRESHOLD=0.05
BASELINE_VERSION=v1.0
SAVE_EVALUATION_REPORTS=true
EVALUATION_REPORT_PREFIX=ci-test-reports/

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT_PATH=logs/ci-test.log

# ============================================================================
# Test Data Configuration
# ============================================================================
# S3 paths to test documents (CYBERSECURITY and LEGAL sections from 10-K)
TEST_DOCUMENT_PATH=test-documents/apple_10k_cybersecurity.html
TEST_LEGAL_DOCUMENT_PATH=test-documents/apple_10k_legal.html
TEST_SAMPLE_QUESTIONS_PATH=test-documents/sample_questions.json

# ============================================================================
# GitHub Actions CI Configuration
# ============================================================================
CI_ENVIRONMENT=true
CI_BUILD_ID=${GITHUB_RUN_ID}
CI_BRANCH=${GITHUB_REF}
CI_COMMIT_SHA=${GITHUB_SHA}

# ============================================================================
# Timeout Configuration (in seconds)
# ============================================================================
API_TIMEOUT=30
S3_TIMEOUT=30
PINECONE_TIMEOUT=60
LLM_TIMEOUT=60
EVALUATION_TIMEOUT=300

# ============================================================================
# Testing Strategy Configuration
# ============================================================================
# Number of test samples for each module
DATA_INGESTION_TEST_SAMPLES=5
RETRIEVAL_TEST_SAMPLES=10
ARGUMENTATION_TEST_SAMPLES=10
EVALUATION_TEST_SAMPLES=20

# ============================================================================
# Error Handling and Retry Configuration
# ============================================================================
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=1.5
DEFAULT_RETRY_DELAY=5

# ============================================================================
# Test Report Configuration
# ============================================================================
GENERATE_JUNIT_REPORT=true
GENERATE_HTML_REPORT=true
REPORT_OUTPUT_DIR=test-reports/

# ============================================================================
# Feature Flags for Testing
# ============================================================================
TEST_EDGE_CASES=true
TEST_ERROR_SCENARIOS=true
TEST_CONCURRENT_REQUESTS=true
TEST_PERFORMANCE_METRICS=true
TEST_REGRESSION_DETECTION=true
